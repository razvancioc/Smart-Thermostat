// --- SETTINGS FOR ST7789 1.69" IPS DISPLAY ---

#define USER_SETUP_INFO "User_Setup"

// 1. Select the correct driver (ST7789)
#define ST7789_DRIVER

// 2. Display dimensions (if the image is slightly offset, you can swap 240 and 280)
#define TFT_WIDTH  240
#define TFT_HEIGHT 280 

// 3. Hardware SPI pins connected to the ESP32
#define TFT_MOSI 23  // SDA / DIN wire
#define TFT_SCLK 18  // SCL / SCK wire
#define TFT_CS   5   // CS (Chip Select) wire
#define TFT_DC   2   // DC (Data/Command) wire
#define TFT_RST  4   // RES (Reset) wire

// 4. Load the necessary fonts for the UI
#define LOAD_GLCD
#define LOAD_FONT2
#define LOAD_FONT4
#define LOAD_FONT6

// 5. SPI Communication speed
#define SPI_FREQUENCY  27000000
